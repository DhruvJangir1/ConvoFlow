{
  "installCommand": "npm install --ignore-scripts && cd backend && npm install --ignore-scripts",
  "buildCommand": "npx vite build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://convoflow-2.onrender.com/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
} 