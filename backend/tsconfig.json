{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "forceConsistentCasingInFileNames": true,
    "types": ["node","jest","vitest/globals"]
  },
  "include": ["src", "server.js", "ws"]
}
